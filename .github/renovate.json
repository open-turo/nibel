{
  "extends": [
    "github>open-turo/renovate-config#v1.18.0",
    "github>open-turo/renovate-config:jvm#v1.18.0"
  ],
  "ignorePresets": ["group:allNonMajor"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 15,
  "packageRules": [
    {
      "groupName": "kotlin",
      "matchPackageNames": ["/androidx.compose.compiler:compiler/"]
    },
    {
      "groupName": "kotlin",
      "matchPackageNames": ["/org.jetbrains.kotlin.*/"]
    },
    {
      "groupName": "kotlin",
      "matchPackageNames": ["/com.google.devtools.ksp/"]
    }
  ]
}
